{
  "expo": {
    "name": "nadirlon",
    "slug": "nadirlon",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-custom.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mwveliz.nardilon",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "splash": {
        "image": "./assets/splash-custom.png",
        "resizeMode": "contain",
        "backgroundColor": "#121212"
      }
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "c69e7564-d901-4c52-aeea-8c5a083ba649"
      }
    }
  }
}